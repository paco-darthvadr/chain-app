# Note, I have used Prisma file based DB throughout the code, this needs changed, but for now this is what im using to test
# Run the prisma db push command to create the dev.db file and apply the schema before running the app with the generate command.
# You can also use prisma studio to view the database contents with npx prisma studio
# commands:
# npx prisma db push
# npx prisma generate
# npx prisma studio 

DATABASE_URL="file:./dev.db"

# Local development URLs
# Note, I used a real domain, Verus login requires https and dev and socket URLS
# should be updated to match the actual domain you will use for development and testing
NEXT_PUBLIC_APP_URL="https://domain.com"
NEXT_PUBLIC_SOCKET_URL="https://socket.domain.com"

TESTNET=true
VERUS_CHANGE_ADDRESS=
VERUS_RPC_USER=
VERUS_RPC_PASSWORD=
VERUS_RPC_PORT=18843
VERUS_RPC_HOST=127.0.0.1

VERUS_SIGNING_ID=@
VERUS_RPC_SYSTEM=
VERUS_SIGNING_WIF=

# ChessGame@ identity for Normal mode (SubID creation + game storage)
# User creates ChessGame@ identity externally and provides these values
CHESSGAME_IDENTITY_NAME=ChessGame@
CHESSGAME_IDENTITY_ADDRESS=
CHESSGAME_SIGNING_WIF=

# CheckersGame@ identity (not yet funded)
CHECKERSGAME_IDENTITY_NAME=CheckersGame@
CHECKERSGAME_IDENTITY_ADDRESS=
CHECKERSGAME_SIGNING_WIF=

VERUS_PRIVATE_KEY=
VERUS_LOGIN_IADDRESS=
# For future
MAINNET_VERUS_LOGIN_IADDRESS=

TESTNET_LOGIN_URL=https://dev.domain.com
TESTNET_LOGIN_SOCKET_URL=https://socket.domain.com
BASE_URL=https://dev.domain.com
NODE_ENV=development
JWT_SECRET=
INTERNAL_API_SECRET=

# SubID Pool: pre-register game SubIDs for showcase mode instant start
# Set to 'false' to disable pool (falls back to on-the-fly registration)
SUBID_POOL_ENABLED=true

# Showcase mode: how many moves to batch before writing to chain (default: 3, range: 1-5)
SHOWCASE_BATCH_SIZE=3
