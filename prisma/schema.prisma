// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  verusId   String   @unique
  displayName String?
  avatarUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gamesAsPlayer1 Game[] @relation("Player1")
  gamesAsPlayer2 Game[] @relation("Player2")
}

model Game {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gameType  String   @default("chess")

  player1   User     @relation("Player1", fields: [player1Id], references: [id])
  player1Id String
  player2   User     @relation("Player2", fields: [player2Id], references: [id])
  player2Id String

  // JSON string representing the board state
  boardState Json
  status     String   @default("IN_PROGRESS") // e.g., IN_PROGRESS, COMPLETED, ABORTED
  winner     String? // 'WHITE', 'BLACK', 'DRAW'
  mode       String   @default("original") // "original", "normal", "showcase"
  boardTheme String   @default("classic")  // board color theme id
  logoMode   String   @default("off")      // "off" | "faded" | "centered"

  // Blockchain storage tracking
  blockchainTxId      String? // Transaction ID on Verus blockchain
  blockchainVdxfKey   String? // VDXF key used for storage
  blockchainStoredAt  DateTime? // When the game was stored on blockchain

  moves Move[]
  gameSession GameSession?
}

model Move {
  id        String   @id @default(cuid())
  game      Game     @relation(fields: [gameId], references: [id])
  gameId    String
  move      String   // e.g., "e2e4"
  movePackage   Json?     // full signed package {subIdName, player, moveNum, move, prevHash}
  signature     String?   // signature for this move
  createdAt DateTime @default(now())
  blockchainTxId String?
  blockchainVdxfKey String?
  blockchainStoredAt DateTime?
}

model ProcessedChallenge {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
}

model GameSession {
  id              String    @id @default(cuid())
  game            Game      @relation(fields: [gameId], references: [id])
  gameId          String    @unique
  subIdName       String?   // "game0001" — null until assigned
  subIdAddress    String?   // i-address of the SubID once created
  gameHash        String?   // final SHA256 hash chain result
  player1FinalSig   String?   // player1's closing signature on gameHash
  player2FinalSig   String?   // player2's closing signature on gameHash
  player1OpeningSig String?   // showcase: player1's opening commitment signature
  player2OpeningSig String?   // showcase: player2's opening commitment signature
  chainSyncedMoveCount Int  @default(0) // showcase: how many moves are confirmed on-chain
  verifiedAt      DateTime? // when server verified all moves + sigs
  storedAt        DateTime? // when written to chain
  txId            String?   // blockchain tx ID
  createdAt       DateTime  @default(now())
}

model GameCounter {
  id        String  @id @default("chess")  // per-game-type: 'chess', 'checkers', etc.
  nextGame  Int     @default(1)
}

model SubIdPool {
  id          String   @id @default(cuid())
  gameType    String   @default("chess")
  subIdName   String   @unique  // "chess-game0017"
  gameNumber  Int                // 17
  address     String?            // i-address once registered
  status      String   @default("registering") // "registering" | "ready" | "used" | "failed"
  commitTxId  String?            // registernamecommitment txid
  createdAt   DateTime @default(now())
  usedAt      DateTime?
  usedByGameId String?           // links to Game.id when assigned

  @@unique([gameType, gameNumber])
}
